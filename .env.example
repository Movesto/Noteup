# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never put real secrets in THIS example file.
# The stack also runs without a .env (docker-compose.yml has dev defaults);
# set these only to override those defaults.

# ── Database ────────────────────────────────────────────────────────────────
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# ── Backend secrets ─────────────────────────────────────────────────────────
# Required in production (the app refuses to start with the dev default when ENV=production).
# Generate, e.g.: openssl rand -hex 32
JWT_SECRET=generate-a-long-random-string
# Comma-separated list of allowed CORS origins for the API.
CORS_ORIGINS=http://localhost:5173
# Max size (MB) for a Notion import .zip. Project exports bundle images we skip,
# so the zip can be large even when the notes are small. Default 1024 (1 GB).
IMPORT_MAX_MB=1024
# Max size (MB) for a single PDF import (read fully into memory). Default 64.
IMPORT_PDF_MAX_MB=64

# ── Frontend ────────────────────────────────────────────────────────────────
# Required in production (the frontend refuses to start without it when NODE_ENV=production).
SESSION_SECRET=generate-a-long-random-string
# Optional: enables Unsplash cover image search. Get a key at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# ── Monitoring ──────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=your_grafana_user
GRAFANA_ADMIN_PASSWORD=generate-a-strong-password
# Optional: Sentry error monitoring (leave blank to disable). Same var used in prod.
SENTRY_DSN=

# Production environment for docker-compose.prod.yml.
# Copy to `.env` ON THE SERVER and fill in real values:  cp .env.prod.example .env
# `.env` is gitignored — never commit real secrets.
#
# Generate each secret with:  openssl rand -hex 32

# ── Database (internal only — never exposed publicly) ────────────────────────
DB_USER=amor
DB_PASSWORD=REPLACE_with_a_strong_password
DB_NAME=amor_db

# ── Backend secret (required; app refuses to start with the dev default) ─────
JWT_SECRET=REPLACE_with_openssl_rand_hex_32

# Your public domain, used for CORS. Comma-separate multiple origins.
CORS_ORIGINS=https://notesapp.uk

# ── Frontend secret (required in production) ─────────────────────────────────
SESSION_SECRET=REPLACE_with_openssl_rand_hex_32

# Optional: enables Unsplash cover images. https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Create a tunnel in the Cloudflare Zero Trust dashboard (Networks → Tunnels),
# point its public hostname at  http://frontend:3000 , and paste the token here.
CLOUDFLARE_TUNNEL_TOKEN=REPLACE_with_cloudflare_tunnel_token

# ── Monitoring (all optional) ────────────────────────────────────────────────
# Netdata Cloud: in Netdata Cloud → Space → Connect Nodes, copy the claim token
# and room id. Leave blank to run Netdata locally (unclaimed).
NETDATA_CLAIM_TOKEN=
NETDATA_CLAIM_ROOMS=
# NETDATA_CLAIM_URL defaults to https://app.netdata.cloud — override only if needed.

# Sentry error + performance monitoring. Create a FastAPI project and paste its
# DSN. Leave blank to disable.
SENTRY_DSN=

# ── Optional import size limits (have sensible defaults) ──────────────────────
# IMPORT_MAX_MB=1024
# IMPORT_PDF_MAX_MB=64

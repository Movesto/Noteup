# Copy to terraform.tfvars and fill in real values.
# Never commit terraform.tfvars — it is gitignored.

aws_region  = "us-east-1"
project     = "amor"
environment = "prod"

# Networking
vpc_cidr             = "10.0.0.0/16"
availability_zones   = ["us-east-1a", "us-east-1b"]
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.10.0/24", "10.0.11.0/24"]

# Database
db_name           = "amor_db"
db_username       = "amor"
db_password       = "CHANGE_ME_strong_password"
db_instance_class = "db.t3.micro"

# Application images (push to ECR first, then set these)
backend_image  = "123456789012.dkr.ecr.us-east-1.amazonaws.com/amor-backend:latest"
frontend_image = "123456789012.dkr.ecr.us-east-1.amazonaws.com/amor-frontend:latest"

# Secrets
jwt_secret          = "CHANGE_ME_long_random_secret"
unsplash_access_key = "CHANGE_ME_unsplash_key"

# Observability
monitoring_allowed_cidr  = "YOUR_IP/32"   # restrict to your IP
grafana_admin_password   = "CHANGE_ME_grafana_password"
monitoring_instance_type = "t3.small"
key_pair_name            = ""             # optional: EC2 key pair for SSH
